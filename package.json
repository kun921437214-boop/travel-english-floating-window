{
  "name": "travel-english-floating-window",
  "version": "1.0.0",
  "private": true,
  "description": "哑巴说话：Mac 桌面悬浮窗英语学习工具",
  "main": "electron/main.js",
  "author": "Codex",
  "license": "MIT",
  "scripts": {
    "app": "node scripts/run-local.mjs",
    "start": "node scripts/run-local.mjs",
    "setup": "node scripts/run-local.mjs --setup-only",
    "dev": "node scripts/dev.mjs",
    "convert:data": "node scripts/convert-xlsx-to-json.mjs",
    "build": "vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "shortcut:desktop": "node scripts/update-desktop-shortcut.mjs",
    "lint": "node --check electron/main.js && node --check electron/preload.js && node --check scripts/convert-xlsx-to-json.mjs && node --check scripts/dev.mjs && node --check scripts/run-local.mjs && node --check scripts/update-desktop-shortcut.mjs && node --check vite.config.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.local.travelenglishfloatingwindow",
    "productName": "哑巴说话",
    "icon": "assets/yaba-icon.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/yaba-icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
